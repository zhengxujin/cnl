---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf())
  .slice(0,SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm Zheng Xujin 👋🏻
    </h4>
    <div class="space-y-16">
      <!-- 个人专业介绍 -->
      <section>
        <article class="space-y-4">
          <p class="animate">
            I am an International Sales Director specialized in power fittings export,
            based in Yueqing, Zhejiang, China — the capital of electrical products in China.
          </p>
          <p class="animate">
            With over 15 years of industry experience, I lead the business of YODO Electric,
            providing reliable power fittings and electrical solutions for global customers.
          </p>
          <p class="animate">
            I'm also a technology enthusiast, passionate about NAS deployment, home network,
            domain management and personal website building.
          </p>
        </article>
      </section>

      <!-- 核心入口：公司官网+博客+WhatsApp -->
      <section class="animate space-y-6">
        <h5 class="font-semibold text-black dark:text-white">
          My Business & Links
        </h5>
        <ul class="flex flex-col gap-4">
          <li>
            <Link href="https://euodo.com" external>
              🏭 Company
            </Link>
          </li>
          <li>
            <Link href="https://zhengxujin.wordpress.com" external>
              📝 Personal Blog
            </Link>
          </li>
          <li>
            <Link href="https://wa.me/8613868791888" external>
              💬 WhatsApp Business: +86 138 6879 1888
            </Link>
          </li>
        </ul>
      </section>

      <!-- 最新文章 原板块完整保留 -->
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Latest posts
          </h5>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <!-- 工作经历 原板块完整保留 -->
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
          <Link href="/work">
            See all work
          </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {work.map(entry => (
            <li>
              <div class="text-sm opacity-75">
                {dateRange(entry.data.dateStart, entry.data.dateEnd)}
              </div>
              <div class="font-semibold text-black dark:text-white">
                {entry.data.company}
              </div>
              <div class="text-sm opacity-75">
                {entry.data.role}
              </div>
              <article>
                <entry.Content />
              </article>
            </li>
          ))}
        </ul>
      </section>

      <!-- 最新项目 原板块完整保留 -->
      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} />
            </li>
          ))}
        </ul>
      </section>

      <!-- 联系方式 完整保留：社交+WhatsApp+邮箱 -->
      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
            Feel free to contact me for power fittings business cooperation,
            technical communication or any inquiries.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="flex gap-x-2 text-nowrap">
            <Link href="https://wa.me/8613868791888" external aria-label="WhatsApp Business">
              WhatsApp
            </Link>
            {"/"}
          </li>
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
